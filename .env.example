# OCR Crafter 環境変数の例（本番配備用。docs/24_DEPLOYMENT_GUIDE.md 参照）
# 使い方: このファイルを .env へコピーし、起動スクリプト/サービス定義から読み込む
# （バックエンド自体は .env を自動読込しない。サービス側で環境変数として設定すること）

# --- バックエンド ---
# CORS許可オリジン（カンマ区切り。本番はフロント配信元のみに絞る）
CORS_ALLOWED_ORIGINS=http://ocr-crafter.example.local

# 認証未設定モード（Admin互換）の無効化。本番は false 必須（docs/22参照）
# false: X-Operatorなし=401 / 不正Role=403 / ロール未指定=viewer
OCRC_ALLOW_UNAUTHENTICATED_ADMIN=false

# PaddleOCRリポジトリの場所（既定: external/PaddleOCR）
# PADDLEOCR_PATH=C:\ocr-crafter\external\PaddleOCR

# Tesseract tessdataの場所（settings.yaml tesseract.tessdata_dir が優先）
# TESSDATA_PREFIX=C:\ocr-crafter\models\tessdata_best

# --- フロントエンド（ビルド時に埋め込み。frontend/.env.production 等で指定） ---
# バックエンドAPIのベースURL（リバースプロキシ経由なら同一オリジンのパス）
VITE_API_BASE=http://ocr-crafter.example.local:8000
